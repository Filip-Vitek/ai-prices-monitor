name: Track AI token prices

on:
  schedule:
    # Twice a day: 06:17 and 18:17 UTC (odd minute avoids GitHub's
    # top-of-the-hour cron congestion, which can delay or drop runs)
    - cron: "17 6,18 * * *"
  workflow_dispatch: {}   # allow manual runs from the Actions tab

permissions:
  contents: write

concurrency:
  group: track-prices
  cancel-in-progress: false

jobs:
  track:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Fetch prices
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: python3 fetch_prices.py

      - name: Commit time series
        run: |
          git config user.name "price-tracker-bot"
          git config user.email "actions@users.noreply.github.com"
          git add data/
          if git diff --cached --quiet; then
            echo "No price changes this run."
          else
            git commit -m "prices: $(date -u +'%Y-%m-%d %H:%M UTC')"
            git push
          fi
